{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://sentinelgateweb-production.up.railway.app/api/:path*" },
    { "source": "/admin/:path*", "destination": "/admin-dashboard/index.html" },
    { "source": "/admin", "destination": "/admin-dashboard/index.html" },
    { "source": "/:path*", "destination": "/gate-display/index.html" },
    { "source": "/", "destination": "/gate-display/index.html" }
  ]
}