# ── Database ──────────────────────────────────────────────────
# Use DATABASE_URL connection string (Railway auto-generates this)
# For Neon, use sslmode=verify-full (not sslmode=require) to avoid deprecation warning
DATABASE_URL=postgresql://sentinel_app:change_me_strong_password@localhost:5432/sentinelgate
# Example Neon URL: postgresql://user:password@ep-gentle-dawn-a1qln1fw-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=verify-full&channel_binding=require

# Local DB fallback variables (used if DATABASE_URL not set):
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sentinelgate
DB_USER=sentinel_app
DB_PASSWORD=change_me_strong_password

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=change_me_256_bit_secret_minimum_32_chars
ADMIN_JWT_SECRET=change_me_admin_256_bit_secret

# ── TOTP ──────────────────────────────────────────────────────
# Each gate gets its own secret stored in DB.
# This is the fallback master secret for bootstrapping.
TOTP_ISSUER=SentinelGate

# ── HMAC ──────────────────────────────────────────────────────
# Per-device secrets are stored in DB (enrolled during device reg).
# Timestamp window for replay prevention (seconds).
HMAC_TIMESTAMP_WINDOW=60

# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── ML Worker ─────────────────────────────────────────────────
ML_WORKER_URL=http://localhost:8000
