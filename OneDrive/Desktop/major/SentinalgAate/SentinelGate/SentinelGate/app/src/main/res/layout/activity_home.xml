<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0A0F14"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SENTINELGATE"
        android:textColor="#00FFB2"
        android:textSize="20sp"
        android:letterSpacing="0.2"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tvRollNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#556677"
        android:textSize="13sp"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="48sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvPendingSync"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#556677"
        android:textSize="12sp"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnAction"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#00FFB2"
        android:textColor="#0A0F14"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnHistory"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="VIEW HISTORY"
        android:backgroundTint="#0A2030"
        android:textColor="#556677"
        android:textSize="12sp"
        android:letterSpacing="0.1"/>

</LinearLayout>
