{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "watchPaths": ["backend/**"],
    "buildCommand": "npm install"
  },
  "deploy": {
    "startCommand": "node backend/src/server.js",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindow": 600
  }
}
