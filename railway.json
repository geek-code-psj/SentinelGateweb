{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm install --omit=dev"
  },
  "deploy": {
    "startCommand": "node src/server.js",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindow": 600,
    "healthcheck": {
      "path": "/",
      "port": 8080,
      "timeout": 60
    }
  }
}